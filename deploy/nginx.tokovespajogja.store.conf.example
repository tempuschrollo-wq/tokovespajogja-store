server {
  listen 80;
  listen [::]:80;
  server_name www.tokovespajogja.store;
  return 301 https://tokovespajogja.store$request_uri;
}

server {
  listen 80;
  listen [::]:80;
  server_name tokovespajogja.store;
  return 301 https://tokovespajogja.store$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name www.tokovespajogja.store;

  ssl_certificate /etc/letsencrypt/live/tokovespajogja.store/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/tokovespajogja.store/privkey.pem;

  return 301 https://tokovespajogja.store$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name tokovespajogja.store;

  ssl_certificate /etc/letsencrypt/live/tokovespajogja.store/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/tokovespajogja.store/privkey.pem;

  client_max_body_size 10m;

  location / {
    proxy_pass http://127.0.0.1:4173;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 60s;
  }
}
